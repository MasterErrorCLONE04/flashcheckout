{
  "version": "3.1",
  "screens": [
    {
      "id": "CHECKOUT_SCREEN",
      "title": "Datos de Envío",
      "terminal": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "checkout_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Finaliza tu Pedido"
              },
              {
                "type": "TextBody",
                "text": "Ingresa los datos para el despacho de tu compra."
              },
              {
                "type": "TextInput",
                "name": "full_name",
                "label": "Nombre Completo",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "address",
                "label": "Dirección",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "city",
                "label": "Ciudad",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "Footer",
                "label": "Confirmar y Pagar",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "full_name": "${form.full_name}",
                    "address": "${form.address}",
                    "city": "${form.city}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}

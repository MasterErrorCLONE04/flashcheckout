generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id                          String    @id @default(cuid())
  slug                        String    @unique
  name                        String
  whatsapp                    String
  userId                      String
  active                      Boolean   @default(true)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  bio                         String?
  logoUrl                     String?
  stripeCurrentPeriodEnd      DateTime?
  stripeCustomerId            String?   @unique
  stripePriceId               String?
  stripeSubscriptionId        String?   @unique
  stripeConnectAccountId      String?   @unique
  stripeConnectChargesEnabled Boolean   @default(false)
  category                    String?   @default("General")
  orders                      Order[]
  products                    Product[]
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Int
  stock     Int      @default(0)
  imageUrl  String?
  active    Boolean  @default(true)
  storeId   String
  createdAt DateTime @default(now())
  category  String?  @default("General")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Order {
  id                      String        @id @default(cuid())
  customerName            String
  customerPhone           String?
  address                 String
  city                    String
  items                   Json
  total                   Int
  status                  String        @default("pending")
  storeId                 String
  createdAt               DateTime      @default(now())
  stripeCheckoutSessionId String?
  mpPaymentId             String?
  mpPreferenceId          String?
  paymentStatus           PaymentStatus @default(PENDING)
  customerWhatsAppId      String?
  source                  String        @default("WEB")
  deliveryRequested       Boolean       @default(false)
  escrowReleased          Boolean       @default(false)
  store                   Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  driverId                String?
  driver                  Driver?       @relation(fields: [driverId], references: [id])
}

model Driver {
  id              String   @id @default(cuid())
  name            String
  phoneNumber     String   @unique
  active          Boolean  @default(true)
  available       Boolean  @default(true)
  rating          Float    @default(5.0)
  ordersDelivered Int      @default(0)
  orders          Order[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WhatsAppSession {
  id              String   @id @default(cuid())
  phoneNumber     String   @unique
  storeId         String?
  cart            Json?
  step            String   @default("START")
  lastInteraction DateTime @default(now()) @updatedAt
  address         String?
  customerName    String?
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id                          String    @id @default(cuid())
  slug                        String    @unique
  name                        String
  whatsapp                    String
  userId                      String
  active                      Boolean   @default(true)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  bio                         String?
  logoUrl                     String?
  stripeCurrentPeriodEnd      DateTime?
  stripeCustomerId            String?   @unique
  stripePriceId               String?
  stripeSubscriptionId        String?   @unique
  stripeConnectAccountId      String?   @unique
  stripeConnectChargesEnabled Boolean   @default(false)
  category                    String?   @default("General")
  systemPrompt                String?
  welcomeMessage              String?
  aiActive                    Boolean   @default(true)
  aiSettings                  Json?     @default("{}")
  verificationLevel           Int       @default(0)
  whatsappVerified            Boolean   @default(false)
  otpCode                     String?
  otpExpiresAt                DateTime?
  idProofUrl                  String?
  strikes                     Int       @default(0)
  pausedReason                String?
  notifiedLimit80             Boolean   @default(false)
  mpAccessToken               String?
  mpPublicKey                 String?
  mpUserId                    String?
  mpConnected                 Boolean   @default(false)
  whatsappInstanceName        String?   @unique
  whatsappConnected           Boolean   @default(false)
  orders                      Order[]
  products                    Product[]
  faqs                        Faq[]
  automations                 Automation[]
  coupons                     Coupon[]
  novaChatHistory             Json?     @default("[]")
  novaChatSessions            NovaChatSession[]
  settings                    Json?     @default("{}")
  referredBySlug              String?
  customers                   Customer[]
  brebConfig                  BrebPaymentConfig?
  brebPaymentIntents          BrebPaymentIntent[]
}

model Customer {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  email       String?
  birthDate   String?
  notes       String?
  city        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, phone])
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Int
  stock     Int      @default(0)
  imageUrl  String?
  active    Boolean  @default(true)
  aiRecommendation Boolean  @default(true)
  aiDescription    String?
  storeId   String
  createdAt DateTime @default(now())
  category  String?  @default("General")
  description String?
  options   Json?
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Order {
  id                      String        @id @default(cuid())
  customerName            String
  customerPhone           String?
  address                 String
  city                    String
  items                   Json
  total                   Int
  status                  String        @default("pending")
  storeId                 String
  createdAt               DateTime      @default(now())
  stripeCheckoutSessionId String?
  mpPaymentId             String?
  mpPreferenceId          String?
  paymentStatus           String        @default("PENDING")
  proofImageUrl           String?
  adminComment            String?
  customerWhatsAppId      String?
  source                  String        @default("WEB")
  deliveryRequested       Boolean       @default(false)
  escrowReleased          Boolean       @default(false)
  reported                Boolean       @default(false)
  store                   Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  driverId                String?
  driver                  Driver?       @relation(fields: [driverId], references: [id])
  brebPaymentIntent       BrebPaymentIntent?
}

model BrebPaymentConfig {
  id                  String   @id @default(cuid())
  storeId             String   @unique
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  enabled             Boolean  @default(false)
  keyType             String
  keyValue            String
  bankProvider        String
  merchantDisplayName String
  participantId       String?
  verificationStatus  String   @default("PENDING")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BrebPaymentIntent {
  id             String             @id @default(cuid())
  orderId        String             @unique
  order          Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  amount         Int
  currency       String             @default("COP")
  reference      String             @unique
  emvPayload     String
  status         String             @default("PENDING")
  expiresAt      DateTime
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  proof          BrebPaymentProof?

  @@index([storeId, status])
}

model BrebPaymentProof {
  id                     String            @id @default(cuid())
  paymentIntentId        String            @unique
  paymentIntent          BrebPaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
  imageUrl               String
  ocrRawText             String?
  bankOrigin             String?
  destinationKey         String?
  extractedAmount        Int?
  extractedTransactionId String?           @unique
  extractedDatetime      DateTime?
  isSuccessScreen        Boolean?
  confidence             Float             @default(0)
  decision               String            @default("PENDING")
  reviewReason           String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([decision])
}

model Driver {
  id              String   @id @default(cuid())
  name            String
  phoneNumber     String   @unique
  active          Boolean  @default(true)
  available       Boolean  @default(true)
  rating          Float    @default(5.0)
  ordersDelivered Int      @default(0)
  orders          Order[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WhatsAppSession {
  id              String   @id @default(cuid())
  phoneNumber     String
  storeId         String   @default("global")
  receivingPhoneId String   @default("global")
  cart            Json?
  step            String   @default("START")
  lastInteraction DateTime @default(now()) @updatedAt
  address         String?
  customerName    String?
  avatarUrl       String?
  messages        Json?
  tags            String[] @default([])
  notes           Json?    @default("[]")
  assignedTo      String   @default("Tú")
  isFavorite      Boolean  @default(false)
  status          String   @default("active")

  @@unique([phoneNumber, storeId])
}

model Automation {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  description String
  active      Boolean  @default(true)
  sentToday   Int      @default(0)
  rate        String   @default("0%")
  rateLabel   String   @default("Tasa de apertura")
  icon        String   @default("👋")
  iconColor   String   @default("bg-amber-100 text-amber-600")
  channels    String[] @default(["WhatsApp"])
  customTemplate String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Coupon {
  id          String   @id @default(cuid())
  code        String
  desc        String
  tipo        String   @default("Código") // 'Código' | 'Automático'
  tipoDesc    String   @default("Porcentaje") // 'Porcentaje' | 'Envío gratis' | 'Monto fijo'
  valor       String
  usos        Int      @default(0)
  validoHasta String   @default("Sin fecha límite")
  estado      String   @default("Activo") // 'Activo' | 'Programado' | 'Inactivo'
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NovaChatSession {
  id              String   @id @default(cuid())
  title           String   @default("Nuevo Chat")
  messages        Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}
